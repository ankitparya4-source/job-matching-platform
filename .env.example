# ============================================
# Job Matching Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://jobmatch:jobmatch_dev_2024@localhost:5432/jobmatch_db

# ---- Auth (NextAuth.js) ----
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# ---- AI Service (Python FastAPI) ----
AI_SERVICE_URL=http://localhost:8000

# ---- File Uploads ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
